# ===== REWRITE ENGINE =====
RewriteEngine On

# 1. Força HTTPS primeiro
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2. WWW → non-WWW
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Corrigir links de posts gerados sem /blog/
<IfModule mod_rewrite.c>
RewriteEngine On

RewriteCond %{IS_SUBREQ} =false
RewriteCond %{REQUEST_URI} !^/blog(?:/|$) [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond /blog/$1/ -U
RewriteRule ^([a-zA-Z0-9_-]+)/?$ /blog/$1/ [R=302,L,NE]
</IfModule>

# 3. Remove /index.html das URLs
RewriteCond %{THE_REQUEST} \s/+(.+/)?index\.html[\s?] [NC]
RewriteRule ^(.+/)?index\.html$ /%1 [R=301,L]

# 4. Redireciona caminhos específicos sem barra final
RedirectMatch 301 ^/faq$ /faq/
RedirectMatch 301 ^/en/faq$ /en/faq/

# ===== ÍNDICE PADRÃO =====
DirectoryIndex index.html index.php

# ===== MIME TYPES CUSTOMIZADOS =====
<IfModule mod_mime.c>
    AddType application/linkset+json api-catalog
    AddType application/json .json
    AddType text/markdown .md
</IfModule>

# ===== BLOQUEAR ACESSO A ARQUIVOS SENSÍVEIS =====
<FilesMatch "(\.env|\.git|wp-config\.php|config\.php|\.htaccess)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# ===== BLOQUEAR LISTAGEM DE DIRETÓRIOS =====
<IfModule mod_dir.c>
    Options -Indexes
</IfModule>

# ===== COMPRESSÃO GZIP =====
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
    AddOutputFilterByType DEFLATE text/x-component application/atom+xml font/woff2
</IfModule>

# ===== CACHE DE BROWSER — OTIMIZADO =====
<IfModule mod_expires.c>
    ExpiresActive On

    # Imagens (1 ano — imutáveis com hash ou versionadas)
    ExpiresByType image/webp                "access plus 1 year"
    ExpiresByType image/png                 "access plus 1 year"
    ExpiresByType image/jpeg                "access plus 1 year"
    ExpiresByType image/gif                 "access plus 1 year"
    ExpiresByType image/svg+xml             "access plus 1 year"
    ExpiresByType image/x-icon              "access plus 1 year"
    ExpiresByType image/vnd.microsoft.icon  "access plus 1 year"

    # Fontes (1 ano)
    ExpiresByType font/woff2                "access plus 1 year"
    ExpiresByType font/woff                 "access plus 1 year"
    ExpiresByType font/ttf                  "access plus 1 year"
    ExpiresByType font/otf                  "access plus 1 year"
    ExpiresByType application/font-woff2    "access plus 1 year"

    # CSS e JS (1 ano) — ver aviso sobre cache-busting no bloco mod_headers abaixo
    ExpiresByType text/css                  "access plus 1 year"
    ExpiresByType application/javascript    "access plus 1 year"
    ExpiresByType text/javascript           "access plus 1 year"

    # PDF (1 mês)
    ExpiresByType application/pdf           "access plus 1 month"

    # HTML e JSON (sem cache — sempre buscar versão atualizada)
    ExpiresByType text/html                 "access plus 0 seconds"
    ExpiresByType application/json          "access plus 0 seconds"
</IfModule>

# ===== CACHE-CONTROL EXPLÍCITO (reforça o Expires) =====
<IfModule mod_headers.c>
     <Files "api-catalog">
          Header set Content-Type "application/linkset+json"
     </Files>
    <FilesMatch "\.(webp|png|jpe?g|gif|svg|ico|woff2?)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    # ATENÇÃO: os arquivos .css/.js NÃO são versionados (sem hash no nome). Com "immutable"
    # o navegador NÃO revalida por 1 ano — ao editar um .css/.js, publique com novo nome
    # ou querystring (ex.: style.css?v=2) para que os visitantes recebam a versão nova.
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>

    # ===== HEADERS DE SEGURANÇA =====
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"

    # ===== OCULTAR INFORMAÇÕES DO SERVIDOR =====
    Header always unset Server
    Header always unset X-Powered-By
    Header always unset X-AspNet-Version
</IfModule>
<IfModule mod_headers.c>
    Header add Link "</.well-known/api-catalog>; rel=\"api-catalog\""
    Header add Link "</docs/api>; rel=\"service-doc\""
</IfModule>
# ===== CONTENT NEGOTIATION — MARKDOWN =====
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_ACCEPT} text/markdown
    RewriteCond %{REQUEST_URI} ^/$
    RewriteRule ^ /index.md [L]

    RewriteCond %{HTTP_ACCEPT} text/markdown
    RewriteCond %{REQUEST_URI} ^/en/?$
    RewriteRule ^ /en/index.md [L]

    RewriteCond %{HTTP_ACCEPT} text/markdown
    RewriteCond %{REQUEST_URI} ^/faq/?$
    RewriteRule ^ /faq/index.md [L]

    RewriteCond %{HTTP_ACCEPT} text/markdown
    RewriteCond %{REQUEST_URI} ^/en/faq/?$
    RewriteRule ^ /en/faq/index.md [L]
</IfModule>

<IfModule mod_headers.c>
    Header set X-Robots-Tag "index, follow"
</IfModule>
